{
  "name": "gutu-lib-query",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/query build",
    "typecheck": "bun run --cwd framework/libraries/query typecheck",
